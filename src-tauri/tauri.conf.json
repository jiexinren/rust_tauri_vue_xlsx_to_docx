{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rust_tauri_vue_xlsx_to_docx",
  "version": "0.1.0",
  "identifier": "com.administrator.rust_tauri_vue_xlsx_to_docx",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "xlsx、xls表格批量生成docx文档小程序——(咸甜适中制作，qq:122581126)",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
